@startuml
hide methods
hide empty members
skinparam classAttributeIconSize 0
skinparam linetype ortho
left to right direction

package "GUIA Ontology" {

class "guide:UniversityCenter" as guide_UniversityCenter {
  + sch:name : langString
}

class "guide:Course" as guide_Course {
  + sch:name : langString
  + sch:courseCode : integer
  + guide:semester : langString
  + guide:courseType : langString
  + sch:numberOfCredits : decimal
}

class "guide:Degree" as guide_Degree {
  + sch:name : langString
}

class "guide:MasterDegree" as guide_MasterDegree
class "guide:BachelorDegree" as guide_BachelorDegree

class "guide:CourseGuide" as guide_CourseGuide {
  + sch:name : langString
  + sch:inLanguage : langString
  + sch:activitiesWorkload : langString
  + sch:description : langString
  + guide:numberOfCredits : decimal
  + guide:teachingPeriod : string
  + guide:teachingPeriodMonths : langString
  + guide:totalHours : langString
  + guide:inpersonHours : langString
  + guide:remoteHours : langString
  + guide:otherInformation : langString
  + guide:periodEndingMonth : langString
  + guide:periodStaringtMonth : langString
}

class "guide:Lecturer" as guide_Lecturer {
  + sch:name : langString
  + sch:email : string
  + guide:office : langString
  + guide:tutorshipsSchedule : langString
}

class "guide:RequiredKnowledge" as guide_RequiredKnowledge {
  + guide:previousCourses : langString
  + guide:previousKnowledge : langString
}

class "guide:Competency" as guide_Competency {
  + sch:name : langString
}

class "guide:LearningResult" as guide_LearningResult {
  + sch:name : langString
}

class "guide:Syllabus" as guide_Syllabus {
  + sch:name : langString
}

class "guide:SyllabusItem" as guide_SyllabusItem {
  + sch:name : langString
}

class "guide:DidacticResource" as guide_DidacticResource {
  + guide:bibliographyTitle : langString
  + guide:bibliographyType : langString
  + guide:bibliographyDescription : langString
}

class "guide:Activity" as guide_Activity {
  + guide:activityDuration : decimal
  + guide:activityFormat : langString
  + guide:activityDescription : langString
  + guide:tecnic : langString
  + guide:attendanceType : langString
}

class "guide:ActivityType1" as guide_ActivityType1 {
  + sch:name : langString
}

class "guide:ActivityType2" as guide_ActivityType2 {
  + sch:name : langString
}

class "guide:EvaluationActivity" as guide_EvaluationActivity

class "guide:RemoteActivity" as guide_RemoteActivity

class "guide:Schedule" as guide_Schedule

class "guide:ScheduleEvent" as guide_ScheduleEvent {
  + sch:name : langString
}

class "guide:EvaluationSystem" as guide_EvaluationSystem {
  + guide:evaluationDescription : langString
}

class "guide:EvaluationTrial" as guide_EvaluationTrial {
  + guide:evaluationType : langString
  + guide:trialWeek : langString
  + guide:trialDescription : langString
  + guide:trialMode : langString
  + guide:trialType : langString
  + guide:evaluationDuration : langString
  + guide:gradePercentage : langString
  + guide:minimumScore : langString
}

class "sch:Organization" as sch_Organization <<external>>
class "sch:Course" as sch_Course <<external>>
class "sch:CourseInstance" as sch_CourseInstance <<external>>
class "sch:Person" as sch_Person <<external>>
class "sch:Syllabus" as sch_Syllabus <<external>>
class "sch:Schedule" as sch_Schedule <<external>>
class "sch:Event" as sch_Event <<external>>
class "om:Unit" as om_Unit <<external>>

guide_UniversityCenter --|> sch_Organization
guide_Course --|> sch_Course
guide_CourseGuide --|> sch_CourseInstance
guide_Lecturer --|> sch_Person
guide_Syllabus --|> sch_Syllabus
guide_Schedule --|> sch_Schedule
guide_ScheduleEvent --|> sch_Event
guide_MasterDegree --|> guide_Degree
guide_BachelorDegree --|> guide_Degree

guide_Syllabus "1" --> "0..*" guide_SyllabusItem : guide:hasItem
guide_CourseGuide "1" --> "0..*" guide_DidacticResource : guide:hasDidacticResource
guide_ScheduleEvent "1" --> "0..*" guide_Activity : guide:hasActivity
guide_Activity "0..*" --> "1" om_Unit : guide:activityDurationUnit
guide_EvaluationTrial "0..*" --> "1" guide_ScheduleEvent : guide:hasScheduleEvent
guide_EvaluationTrial "0..*" --> "0..*" guide_Competency : guide:involvesCompetency
guide_CourseGuide "1" --> "0..*" guide_LearningResult : guide:hasLearningResult
guide_EvaluationSystem "1" --> "0..*" guide_EvaluationTrial : guide:hasEvaluationTrial
guide_Degree "1" --> "0..*" guide_Course : guide:hasCourse
guide_CourseGuide "1" --> "1" guide_EvaluationSystem : guide:hasEvaluation
guide_UniversityCenter "1" --> "0..*" guide_Degree : guide:offers
guide_CourseGuide "1" --> "0..*" guide_Competency : guide:hasCompetency
guide_CourseGuide "1" --> "1" guide_Schedule : sch:courseSchedule
guide_Schedule "1" --> "0..*" guide_ScheduleEvent : sch:eventSchedule
guide_CourseGuide "1" --> "0..1" guide_Lecturer : sch:director
guide_CourseGuide "1" --> "0..*" guide_Lecturer : sch:instructor
guide_Course "1" --> "0..*" guide_CourseGuide : sch:hasCourseInstance

note bottom of guide_EvaluationActivity
No explicit datatype or object properties
are declared for this class in the OWL file.
end note

note bottom of guide_RemoteActivity
No explicit datatype or object properties
are declared for this class in the OWL file.
end note

}
@enduml
