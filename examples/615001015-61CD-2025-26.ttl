        ns2:RA94,
        ns2:RA95 ;
    ns1:inpersonHours "34 horas (43.6%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "El curso es eminentemente práctico, por lo que es aconsejable que los alumnos traigan a clase sus portátiles para poder trabajar durante las horas de clase."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStaringtMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26"^^xsd:gYear ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "65 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <http://data.org/615001015/2025-26/eventSchedule> ;
    schema:description "El objetivo de esta asignatura es proporcionar la base teórica y práctica sobre los fundamentos metodológicos y tecnológicos implicados en la generación y publicación de datos en la Web de datos enlazados, así como en forma de grafos de conocimientos. En concreto, se presentarán: los conceptos de Web Semántica, Web de datos enlazados y grafos de conocimientos, así como de datos abiertos, lenguajes de representación de datos en la Web, metodología y tecnologías de soporte a la generación y publicación de datos enlazados, ontologías y vocabularios utilizados, fuentes de datos representativas, como DBpedia, Wikidata, Geonames, etc., y aplicaciones que hacen uso de datos enlazados y de grafos de conocimientos."@es ;
    schema:director ns2:andreajesus.cimmino%40upm.es ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor ns2:andreajesus.cimmino%40upm.es .

