    schema:courseCode 615001015 ;
    schema:hasCourseInstance <http://data.org/615001015/2025-26> ;
    schema:name "Semantic Web, Linked Data And Knowledge Graphs"@en,
        "Web Semántica, Linked Data y Grafos de Conocimientos"@es ;
    schema:numberOfCredits 3.0 .

<http://data.org/615001015/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency ns2:CB01,
