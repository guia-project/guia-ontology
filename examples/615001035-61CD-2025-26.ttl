    schema:hasCourseInstance <http://data.org/615001035/2025-26> ;
    schema:name "Intelligent Systems"@en,
        "Sistemas Inteligentes"@es ;
    schema:numberOfCredits 6.0 .

<http://data.org/615001035/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency ns2:CE13,
        ns2:CE14,
        ns2:CE16,
        ns2:CG01 ;
    ns1:hasDidacticResource <http://data.org/615001035/2025-26/didactic_resource/1>,
        <http://data.org/615001035/2025-26/didactic_resource/2>,
        <http://data.org/615001035/2025-26/didactic_resource/3>,
