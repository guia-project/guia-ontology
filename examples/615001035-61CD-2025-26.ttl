ns2:61CD%20-%20Grado%20en%20Ciencia%20de%20Datos%20e%20Inteligencia%20Artificial a ns1:BachelorDegree,
        ns1:Degree ;
    ns1:hasCourse ns2:615001035 ;
    schema:name "61CD - Grado en Ciencia de Datos e Inteligencia Artificial"@es .

ns2:RA124 a ns1:LearningResult ;
    ns1:learningResultCode "RA124" ;
    ns1:learningResultDescription "Dado un problema real elegir la tecnología de ciencia de datos o de inteligencia artificial existente en el mercado más apropiada para su solución y diseñar su desarrollo e integración analizando la viabilidad de su solución, lo que se puede y no se puede conseguir a través del estado actual de desarrollo de la tecnología usada, y lo que se espera que avance en el futuro"@es .

ns2:RA63 a ns1:LearningResult ;
    ns1:learningResultCode "RA63" ;
    ns1:learningResultDescription "RA67"@es .

ns2:RA73 a ns1:LearningResult ;
    ns1:learningResultCode "RA73" ;
    ns1:learningResultDescription "Analizar y diseñar sociedades de agentes que simulen comportamientos inteligentes"@es .

