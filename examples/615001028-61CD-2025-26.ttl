    schema:hasCourseInstance <http://data.org/615001028/2025-26> ;
    schema:name "Image Analysis Fundamentals"@en,
        "Fundamentos de Análisis de Imágenes"@es ;
    schema:numberOfCredits 3.0 .

<http://data.org/615001028/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency ns2:CB02,
        ns2:CE01,
        ns2:CE16,
        ns2:CG01 ;
    ns1:hasDidacticResource <http://data.org/615001028/2025-26/didactic_resource/1>,
        <http://data.org/615001028/2025-26/didactic_resource/2>,
        <http://data.org/615001028/2025-26/didactic_resource/3>,
