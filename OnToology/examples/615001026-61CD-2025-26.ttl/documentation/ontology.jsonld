  } ],
  "https://schema.org/name" : [ {
    "@language" : "es",
    "@value" : "61CD - Grado en Ciencia de Datos e Inteligencia Artificial"
  } ]
}, {
  "@id" : "http://data.org/CB03",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CB03"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"
  } ]
}, {
  "@id" : "http://data.org/CB05",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CB05"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"
  } ]
}, {
  "@id" : "http://data.org/CE03",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CE03"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Capacidad para analizar fenómenos complejos mediante la probabilidad y estadística, y plantear modelos matemáticos de los mismos en situaciones concretas, así como formular, modelizar y resolver problemas de optimización matemática relacionados con la ciencia de datos y la inteligencia artificial."
  } ]
}, {
  "@id" : "http://data.org/CE10",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CE10"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Capacidad para aplicar las metodologías y las técnicas adecuadas de análisis y explotación de datos sobre datos disponibles, incluidos los poco estructurados o de estructura compleja (como los que contienen series temporales, los provenientes de redes sociales, etc.), para descubrir nuevas relaciones y proporcionar conocimiento y una comprensión intuitiva precisa y profunda sobre problemas científicos o procesos organizacionales reales y así respaldar la toma de decisiones."
  } ]
}, {
  "@id" : "http://data.org/CG01",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CG01"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Capacidad de trabajo en equipo, en entornos interdisciplinares y complejos, negociando y resolviendo conflictos, diseñando soluciones eficientes, fiables, robustas y responsables."
  } ]
}, {
  "@id" : "http://data.org/CG02",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CG02"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Capacidad para organizar y planificar tareas y proyectos, identificando objetivos, prioridades, plazos, recursos y riesgos, y controlando los procesos establecidos."
  } ]
}, {
  "@id" : "http://data.org/CG04",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CG04"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Capacidad para innovar y encontrar soluciones creativas en situaciones complejas o de incertidumbre en el ámbito de la ingeniería."
  } ]
}, {
