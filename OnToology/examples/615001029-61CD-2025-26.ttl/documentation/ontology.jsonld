    "@value" : "CB01"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"
  } ]
}, {
  "@id" : "http://data.org/CB02",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CB02"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"
  } ]
}, {
  "@id" : "http://data.org/CB03",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CB03"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"
  } ]
}, {
  "@id" : "http://data.org/CB04",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CB04"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"
  } ]
}, {
  "@id" : "http://data.org/CB05",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CB05"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"
  } ]
}, {
  "@id" : "http://data.org/CE11",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CE11"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Capacidad para aplicar métodos generales de ciencia de datos e inteligencia artificial para desarrollar software que explote los datos de un dominio concreto científico o de negocio."
  } ]
}, {
  "@id" : "http://data.org/CE15",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CE15"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Capacidad para describir y aplicar las técnicas de aprendizaje automático y estadística avanzada que permitan transformar los datos en conocimiento y proporcionar sistemas capaces de resolver problemas de clasificación supervisada y no supervisada, así como de búsqueda de relaciones de independencia condicional entre variables relacionadas."
  } ]
}, {
  "@id" : "http://data.org/CE17",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CE17"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Capacidad para describir y aplicar los mecanismos de interacción en sociedades es artificiales e híbridas, incluyendo aspectos relacionados con el procesamiento de lenguaje natural, la decisión colectiva, la negociación y la coordinación."
  } ]
}, {
  "@id" : "http://data.org/CG01",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CG01"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Capacidad de trabajo en equipo, en entornos interdisciplinares y complejos, negociando y resolviendo conflictos, diseñando soluciones eficientes, fiables, robustas y responsables."
  } ]
}, {
  "@id" : "http://data.org/CG02",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CG02"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Capacidad para organizar y planificar tareas y proyectos, identificando objetivos, prioridades, plazos, recursos y riesgos, y controlando los procesos establecidos."
  } ]
}, {
  "@id" : "http://data.org/CG04",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CG04"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Capacidad para innovar y encontrar soluciones creativas en situaciones complejas o de incertidumbre en el ámbito de la ingeniería."
  } ]
}, {
  "@id" : "http://data.org/CG06",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CG06"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Identificar y utilizar las tecnologías de la información y las comunicaciones más adecuadas en el ámbito de la ingeniería."
  } ]
}, {
  "@id" : "http://data.org/CG07",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CG07"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Capacidad para integrar aspectos sociales, ambientales, económicos y éticos inherentes a la ingeniería, analizando sus impactos, y comprometiéndose con la búsqueda de soluciones a retos del desarrollo sostenible."
  } ]
}, {
  "@id" : "http://data.org/E.T.S%20De%20Ing.%20De%20Sistemas%20Inform%C3%A1ticos",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/UniversityCenter"
  } ],
  "https://guia.org/offers" : [ {
    "@id" : "http://data.org/61CD%20-%20Grado%20en%20Ciencia%20de%20Datos%20e%20Inteligencia%20Artificial"
  } ],
  "https://schema.org/name" : [ {
    "@value" : "E.T.S De Ing. De Sistemas Informáticos"
  } ]
}, {
  "@id" : "http://data.org/RA101",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/LearningResult"
  } ],
  "https://guia.org/learningResultCode" : [ {
    "@value" : "RA101"
  } ],
  "https://guia.org/learningResultDescription" : [ {
    "@language" : "es",
    "@value" : "Conocer y aplicar la metodología apropiada para el ajuste de series temporales."
  } ]
}, {
  "@id" : "http://data.org/RA102",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/LearningResult"
  } ],
  "https://guia.org/learningResultCode" : [ {
    "@value" : "RA102"
  } ],
  "https://guia.org/learningResultDescription" : [ {
    "@language" : "es",
    "@value" : "Conocer y aplicar técnicas de preprocesamiento de datos y reducción de dimensionalidad de variables discriminantes"
  } ]
}, {
  "@id" : "http://data.org/RA103",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/LearningResult"
  } ],
  "https://guia.org/learningResultCode" : [ {
    "@value" : "RA103"
  } ],
  "https://guia.org/learningResultDescription" : [ {
    "@language" : "es",
    "@value" : "Conocer y aplicar técnicas de reducción de dimensionalidad y modelización de datos multivariantes."
  } ]
}, {
  "@id" : "http://data.org/RA104",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/LearningResult"
  } ],
  "https://guia.org/learningResultCode" : [ {
    "@value" : "RA104"
  } ],
  "https://guia.org/learningResultDescription" : [ {
    "@language" : "es",
    "@value" : "Conocer y aplicar las principales técnicas para explorar, describir y analizar datos mulivariantes."
  } ]
