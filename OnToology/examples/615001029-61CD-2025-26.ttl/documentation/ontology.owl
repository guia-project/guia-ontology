        <guia:hasDidacticResource rdf:resource="http://data.org/615001029/2025-26/didactic_resource/7"/>
        <guia:hasDidacticResource rdf:resource="http://data.org/615001029/2025-26/didactic_resource/8"/>
        <guia:hasDidacticResource rdf:resource="http://data.org/615001029/2025-26/didactic_resource/9"/>
        <guia:hasEvaluation rdf:resource="http://data.org/615001029/2025-26/evaluation"/>
        <guia:hasLearningResult rdf:resource="http://data.org/RA101"/>
        <guia:hasLearningResult rdf:resource="http://data.org/RA102"/>
