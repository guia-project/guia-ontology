  } ],
  "https://schema.org/description" : [ {
    "@language" : "es",
    "@value" : "Se estudian los fundamentos de la Robótica, así como su relación con la Inteligencia Artificial. Se estudian los fundamentos teóricos de los manipuladores y su aplicación al diseño y modelado de robots industriales. Se revisan diferentes arquitecturas de diseño de software para desarrollar sistemas de control de robots móviles. Finalmente, se analizan los sistemas de percepción del entorno de navegación del robot."
  } ],
