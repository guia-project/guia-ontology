  "https://guia.org/otherInformation" : [ {
    "@language" : "es",
    "@value" : "La asignatura se relaciona con el ODS9 y el ODS11.\nLa asignatura se relaciona con el ODS9 (Industria, Innovación e Infraestructuras). Los sistemas robóticos han estado siempre presentes en gran parte de la industria moderna y en la actualidad son fundamentales en muchas de las áreas donde la innovación es un elemento primordial y se establecen como básicos en muchas de las infraestructuras de futuro."
  } ],
  "https://guia.org/periodEndingMonth" : [ {
    "@language" : "es",
    "@value" : "Junio"
  } ],
  "https://guia.org/periodStaringtMonth" : [ {
    "@language" : "es",
    "@value" : "Febrero"
  } ],
