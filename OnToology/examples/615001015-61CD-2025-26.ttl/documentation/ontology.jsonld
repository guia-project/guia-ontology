  "@id" : "http://data.org/61CD%20-%20Grado%20en%20Ciencia%20de%20Datos%20e%20Inteligencia%20Artificial",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/BachelorDegree"
  }, {
    "@id" : "https://guia.org/Degree"
  } ],
  "https://guia.org/hasCourse" : [ {
    "@id" : "http://data.org/615001015"
  } ],
  "https://schema.org/name" : [ {
    "@language" : "es",
    "@value" : "61CD - Grado en Ciencia de Datos e Inteligencia Artificial"
  } ]
}, {
  "@id" : "http://data.org/CB01",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/code" : [ {
    "@value" : "CB01"
  } ],
  "https://guia.org/description" : [ {
    "@language" : "es",
    "@value" : "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"
  } ]
}, {
  "@id" : "http://data.org/CB02",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/code" : [ {
    "@value" : "CB02"
  } ],
  "https://guia.org/description" : [ {
    "@language" : "es",
    "@value" : "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"
  } ]
}, {
  "@id" : "http://data.org/CB03",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/code" : [ {
    "@value" : "CB03"
  } ],
  "https://guia.org/description" : [ {
    "@language" : "es",
    "@value" : "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"
  } ]
}, {
  "@id" : "http://data.org/CB04",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/code" : [ {
    "@value" : "CB04"
  } ],
  "https://guia.org/description" : [ {
    "@language" : "es",
    "@value" : "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"
  } ]
}, {
  "@id" : "http://data.org/CB05",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/code" : [ {
    "@value" : "CB05"
  } ],
  "https://guia.org/description" : [ {
    "@language" : "es",
    "@value" : "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"
  } ]
}, {
  "@id" : "http://data.org/CE11",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/code" : [ {
    "@value" : "CE11"
  } ],
  "https://guia.org/description" : [ {
    "@language" : "es",
    "@value" : "Capacidad para aplicar métodos generales de ciencia de datos e inteligencia artificial para desarrollar software que explote los datos de un dominio concreto científico o de negocio."
  } ]
}, {
  "@id" : "http://data.org/CE14",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/code" : [ {
    "@value" : "CE14"
  } ],
  "https://guia.org/description" : [ {
    "@language" : "es",
    "@value" : "Capacidad para describir las técnicas de adquisición y representación del conocimiento, y modelos de razonamiento en entornos centralizados y distribuidos, y utilizarlas para desarrollar sistemas basados en el conocimiento orientados a la resolución de problemas y toma de decisiones que requieran conducta inteligente."
  } ]
}, {
  "@id" : "http://data.org/CG01",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/code" : [ {
    "@value" : "CG01"
  } ],
  "https://guia.org/description" : [ {
    "@language" : "es",
    "@value" : "Capacidad de trabajo en equipo, en entornos interdisciplinares y complejos, negociando y resolviendo conflictos, diseñando soluciones eficientes, fiables, robustas y responsables."
  } ]
}, {
  "@id" : "http://data.org/CG02",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
