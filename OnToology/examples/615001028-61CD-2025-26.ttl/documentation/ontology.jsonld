  "https://schema.org/description" : [ {
    "@language" : "es",
    "@value" : "Esta asignatura tiene como objetivo estudiar un conjunto de técnicas que permitan extraer información útil a partir de imágenes digitales. Se estudiará su proceso de formación, las técnicas de procesamiento y descripción más habituales y su aplicación en problemas prácticos. Se utilizarán las bibliotecas y entornos más habituales de procesamiento y análisis de imágenes."
  } ],
