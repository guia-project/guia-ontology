        <guia:competencyCode>CE05</guia:competencyCode>
        <guia:competencyDescription xml:lang="es">Capacidad de diseñar e implementar los procesos de selección, limpieza, transformación, integración y verificación de la calidad de los datos de cara a su posterior tratamiento.</guia:competencyDescription>
    </NamedIndividual>
    


