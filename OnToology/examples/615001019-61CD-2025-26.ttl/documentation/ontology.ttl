                                    <https://guia.org/hasEvaluation> <http://data.org/615001019/2025-26/evaluation> ;
                                    <https://guia.org/hasLearningResult> <http://data.org/RA54> ,
                                                                         <http://data.org/RA55> ,
                                                                         <http://data.org/RA89> ;
