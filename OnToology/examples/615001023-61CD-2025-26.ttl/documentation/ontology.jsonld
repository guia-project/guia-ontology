  "https://schema.org/description" : [ {
    "@language" : "es",
    "@value" : "La computación social es un área de conocimiento que surge de la intersección de los sistemas computacionales y del análisis del comportamiento social. La aparición de internet ha sido un factor fundamental para que durante los últimos años se haya incorporado un componente social a la Web, de tal forma que los usuarios establecen conexiones, comparten intereses, publican y consumen contenidos, colaboran para resolver problemas sociales y establecen negocios. En esta asignatura se analizan los principios de la computación social, así como las herramientas que facilitan la construcción de máquinas sociales en la Web."
  } ],
  "https://schema.org/director" : [ {
    "@id" : "http://data.org/raul.lara%40upm.es"
  } ],
