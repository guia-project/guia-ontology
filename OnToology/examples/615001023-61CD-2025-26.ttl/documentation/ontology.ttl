###  http://data.org/615001023/2025-26
<http://data.org/615001023/2025-26> rdf:type owl:NamedIndividual ,
                                             <https://guia.org/CourseGuide> ;
                                    <https://guia.org/hasCompetency> <http://data.org/CB03> ,
                                                                     <http://data.org/CE13> ,
                                                                     <http://data.org/CE17> ,
                                                                     <http://data.org/CG01> ,
                                                                     <http://data.org/CG07> ;
                                    <https://guia.org/hasDidacticResource> <http://data.org/615001023/2025-26/didactic_resource/1> ,
                                                                           <http://data.org/615001023/2025-26/didactic_resource/2> ,
                                                                           <http://data.org/615001023/2025-26/didactic_resource/3> ,
                                                                           <http://data.org/615001023/2025-26/didactic_resource/4> ,
                                                                           <http://data.org/615001023/2025-26/didactic_resource/5> ,
