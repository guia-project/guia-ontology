        <guia:inpersonHours xml:lang="es">38 horas (48.7%)</guia:inpersonHours>
        <guia:numberOfCredits rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">3.0</guia:numberOfCredits>
        <guia:otherInformation xml:lang="es"></guia:otherInformation>
        <guia:periodEndingMonth xml:lang="es">Junio</guia:periodEndingMonth>
        <guia:periodStaringtMonth xml:lang="es">Febrero</guia:periodStaringtMonth>
        <guia:teachingPeriod rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">2025-26</guia:teachingPeriod>
        <guia:teachingPeriodMonths xml:lang="es">Febrero-Junio</guia:teachingPeriodMonths>
