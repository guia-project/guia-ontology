}, {
  "@id" : "http://data.org/CB01",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CB01"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"
  } ]
}, {
  "@id" : "http://data.org/CB02",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CB02"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"
  } ]
}, {
  "@id" : "http://data.org/CB05",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CB05"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"
  } ]
}, {
  "@id" : "http://data.org/CE02",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CE02"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Capacidad de diseñar, implementar y evaluar soluciones algorítmicas eficientes para problemas computacionales de ciencia de datos e inteligencia artificial de acuerdo con los requisitos establecidos."
  } ]
}, {
  "@id" : "http://data.org/CG01",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CG01"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Capacidad de trabajo en equipo, en entornos interdisciplinares y complejos, negociando y resolviendo conflictos, diseñando soluciones eficientes, fiables, robustas y responsables."
  } ]
}, {
  "@id" : "http://data.org/CG02",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CG02"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Capacidad para organizar y planificar tareas y proyectos, identificando objetivos, prioridades, plazos, recursos y riesgos, y controlando los procesos establecidos."
  } ]
}, {
  "@id" : "http://data.org/CG03",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CG03"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Capacidad de emprendimiento y de liderazgo para dirigir y gestionar equipos y proyectos, generando confianza y compromiso en el grupo de colaboradores."
  } ]
}, {
  "@id" : "http://data.org/CG04",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/Competency"
  } ],
  "https://guia.org/competencyCode" : [ {
    "@value" : "CG04"
  } ],
  "https://guia.org/competencyDescription" : [ {
    "@language" : "es",
    "@value" : "Capacidad para innovar y encontrar soluciones creativas en situaciones complejas o de incertidumbre en el ámbito de la ingeniería."
  } ]
}, {
  "@id" : "http://data.org/CG06",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
