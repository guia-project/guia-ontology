        <guia:hasDidacticResource rdf:resource="http://data.org/615001016/2025-26/didactic_resource/5"/>
        <guia:hasDidacticResource rdf:resource="http://data.org/615001016/2025-26/didactic_resource/6"/>
        <guia:hasEvaluation rdf:resource="http://data.org/615001016/2025-26/evaluation"/>
