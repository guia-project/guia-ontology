        <schema:hasCourseInstance rdf:resource="http://data.org/615001033/2025-26"/>
        <schema:name xml:lang="es">Aprendizaje Automático II</schema:name>
        <schema:name xml:lang="en">Machine Learning II</schema:name>
        <schema:numberOfCredits rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">6.0</schema:numberOfCredits>
    </NamedIndividual>
    


    <!-- http://data.org/615001033/2025-26 -->


    <NamedIndividual rdf:about="http://data.org/615001033/2025-26">
        <rdf:type rdf:resource="https://guia.org/CourseGuide"/>
        <guia:hasCompetency rdf:resource="http://data.org/CB01"/>
        <guia:hasCompetency rdf:resource="http://data.org/CB02"/>
        <guia:hasCompetency rdf:resource="http://data.org/CB05"/>
        <guia:hasCompetency rdf:resource="http://data.org/CE11"/>
