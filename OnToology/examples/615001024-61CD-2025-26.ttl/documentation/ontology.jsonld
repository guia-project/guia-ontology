  "https://schema.org/description" : [ {
    "@language" : "es",
    "@value" : "En esta asignatura se describirá la Arquitectura Hardware y Software que se utiliza para poder procesar el\nenorme volumen de datos que suele manejarse en la Ciencia de Datos y en la Inteligencia Artificial.\nPara ello se abordarán los siguientes temas:\n- Computación de alto rendimiento\n- Sistemas Distribuidos\n- Procesamiento batch de datos"
  } ],
  "https://schema.org/director" : [ {
    "@id" : "http://data.org/a.mozo%40upm.es"
  } ],
