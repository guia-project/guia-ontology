                                                                     <http://data.org/CG06> ;
                                    <https://guia.org/hasDidacticResource> <http://data.org/615001024/2025-26/didactic_resource/1> ;
                                    <https://guia.org/hasEvaluation> <http://data.org/615001024/2025-26/evaluation> ;
