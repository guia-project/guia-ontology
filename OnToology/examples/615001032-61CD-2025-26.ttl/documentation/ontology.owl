        <guia:learningResultCode>RA165</guia:learningResultCode>
        <guia:learningResultDescription xml:lang="es">Aplicar esta metodología en el diseño de este tipo de herramientas</guia:learningResultDescription>
    </NamedIndividual>
    


    <!-- http://data.org/RA166 -->


    <NamedIndividual rdf:about="http://data.org/RA166">
