  "https://schema.org/description" : [ {
    "@language" : "es",
    "@value" : "Con esta asignatura, los alumnos conocerán los fundamentos de la visualización de cualquier tipo de información.Se presentarán las tecnologías y los fundamentos necesarios para crear las herramientas de visualización de información:\nFundamentos de la visualización de la información\nAbstracciones de datos y tareas\nTécnicas de interacción y de codificación visual\nMétodos de diseño"
  } ],
  "https://schema.org/director" : [ {
    "@id" : "http://data.org/manuel.ottaviano%40upm.es"
  } ],
