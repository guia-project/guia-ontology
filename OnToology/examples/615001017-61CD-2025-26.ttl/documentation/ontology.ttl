                                                                           <http://data.org/615001017/2025-26/didactic_resource/9> ;
                                    <https://guia.org/hasEvaluation> <http://data.org/615001017/2025-26/evaluation> ;
                                    <https://guia.org/hasLearningResult> <http://data.org/RA78> ,
