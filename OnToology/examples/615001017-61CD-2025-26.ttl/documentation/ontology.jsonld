}, {
  "@id" : "http://data.org/RA78",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/LearningResult"
  } ],
  "https://guia.org/learningResultCode" : [ {
    "@value" : "RA78"
  } ],
  "https://guia.org/learningResultDescription" : [ {
    "@language" : "es",
    "@value" : "Aplicar técnicas y análisis de mercados, para seguir las acciones necesarias para definir un objetivo en una estrategia empresarial."
  } ]
}, {
  "@id" : "http://data.org/RA79",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://guia.org/LearningResult"
  } ],
  "https://guia.org/learningResultCode" : [ {
    "@value" : "RA79"
  } ],
  "https://guia.org/learningResultDescription" : [ {
    "@language" : "es",
    "@value" : "Identificar y describir las áreas funcionales de una empresa y sus responsabilidades, así como el análisis y diseño de los procesos de negocio"
  } ]
}, {
  "@id" : "http://data.org/RA80",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
