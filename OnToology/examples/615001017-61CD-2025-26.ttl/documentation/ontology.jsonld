  "https://schema.org/description" : [ {
    "@language" : "es",
    "@value" : "La asignatura de Fundamentos de Economía y Administración de Empresas es una primera aproximación al entorno económico empresarial con un enfoque teórico-práctico. En el primer bloque se abordan temas referentes a la teoría económica; en el segundo, temas relativos al concepto de empresa, la estrategia y la dirección empresarial; y, en el tercero, se recorren las áreas funcionales clásicas de la empresa: finanzas, producción y marketing."
  } ],
