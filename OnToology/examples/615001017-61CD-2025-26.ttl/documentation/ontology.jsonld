  } ],
  "https://guia.org/learningResultCode" : [ {
    "@value" : "RA80"
  } ],
  "https://guia.org/learningResultDescription" : [ {
    "@language" : "es",
    "@value" : "Capacidad para identificar y asegurar el cumplimiento de los valores y principios éticos, legales, democráticos, de igualdad y derechos fundamentales dentro de una organización"
  } ]
