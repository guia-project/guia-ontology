    <!-- https://guia.org/Activity -->


    <owl:Class rdf:about="https://guia.org/Activity">
        <rdfs:comment xml:lang="en">A teaching or learning activity carried out as part of the course, such as lectures, labs, seminars, tutorials, or independent work.</rdfs:comment>
        <rdfs:label xml:lang="en">Activity</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/ActivityType1 -->


    <owl:Class rdf:about="https://guia.org/ActivityType1">
        <rdfs:comment xml:lang="en">A first-level category used to classify academic activities according to the pedagogical structure adopted in the course guide.</rdfs:comment>
        <rdfs:label xml:lang="en">Activity Type 1</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/ActivityType2 -->


    <owl:Class rdf:about="https://guia.org/ActivityType2">
        <rdfs:comment xml:lang="en">A second-level or more specific category used to refine the classification of academic activities in the course guide.</rdfs:comment>
        <rdfs:label xml:lang="en">Activity Type 2</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/BachelorDegree -->


    <owl:Class rdf:about="https://guia.org/BachelorDegree">
        <rdfs:subClassOf rdf:resource="https://guia.org/Degree"/>
        <rdfs:comment xml:lang="en">An undergraduate degree programme that provides foundational higher education in a given field of study.</rdfs:comment>
        <rdfs:label xml:lang="en">Bachelor&apos;s Degree</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/Competency -->


    <owl:Class rdf:about="https://guia.org/Competency">
        <rdfs:comment xml:lang="en">A capability, skill, or integrated learning outcome that students are expected to develop through the course.</rdfs:comment>
        <rdfs:label xml:lang="en">Competency</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/Course -->


    <owl:Class rdf:about="https://guia.org/Course">
        <rdfs:subClassOf rdf:resource="https://schema.org/Course"/>
        <rdfs:comment xml:lang="en">An academic course as defined in the GUIA model, typically described through its content, teaching organization, assessment, and related course guide.</rdfs:comment>
        <rdfs:label xml:lang="en">Course</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/CourseGuide -->


    <owl:Class rdf:about="https://guia.org/CourseGuide">
        <rdfs:subClassOf rdf:resource="https://schema.org/CourseInstance"/>
        <rdfs:comment xml:lang="en">A structured academic document that describes a course, including objectives, contents, methodology, resources, schedule, and evaluation.</rdfs:comment>
        <rdfs:label xml:lang="en">Course Guide</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/Degree -->


    <owl:Class rdf:about="https://guia.org/Degree">
        <rdfs:comment xml:lang="en">An academic degree programme that structures and groups courses within a formal higher education curriculum.</rdfs:comment>
        <rdfs:label xml:lang="en">Degree</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/DidacticResource -->


    <owl:Class rdf:about="https://guia.org/DidacticResource">
        <rdfs:comment xml:lang="en">A teaching or learning resource used in the course, such as readings, software, audiovisual material, or practical tools.</rdfs:comment>
        <rdfs:label xml:lang="en">Didactic Resource</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/EvaluationActivity -->


    <owl:Class rdf:about="https://guia.org/EvaluationActivity">
        <rdfs:comment xml:lang="en">An activity specifically intended to assess student performance, achievement, or progress within the course.</rdfs:comment>
        <rdfs:label xml:lang="en">Evaluation Activity</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/EvaluationSystem -->


    <owl:Class rdf:about="https://guia.org/EvaluationSystem">
        <rdfs:comment xml:lang="en">The overall framework that defines how student learning is assessed in a course, including criteria, components, and grading structure.</rdfs:comment>
        <rdfs:label xml:lang="en">Evaluation System</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/EvaluationTrial -->


    <owl:Class rdf:about="https://guia.org/EvaluationTrial">
        <rdfs:comment xml:lang="en">A specific assessment instance or examination opportunity within the evaluation system, such as an ordinary or extraordinary attempt.</rdfs:comment>
        <rdfs:label xml:lang="en">Evaluation Trial</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/LearningResult -->


    <owl:Class rdf:about="https://guia.org/LearningResult">
        <rdfs:comment xml:lang="en">A specific and assessable statement of what a student is expected to know, understand, or be able to do after completing the course.</rdfs:comment>
        <rdfs:label xml:lang="en">Learning Result</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/Lecturer -->


    <owl:Class rdf:about="https://guia.org/Lecturer">
        <rdfs:subClassOf rdf:resource="https://schema.org/Person"/>
        <rdfs:comment xml:lang="en">A teaching person responsible for delivering, coordinating, or supporting a course within an academic programme.</rdfs:comment>
        <rdfs:label xml:lang="en">Lecturer</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/MasterDegree -->


    <owl:Class rdf:about="https://guia.org/MasterDegree">
        <rdfs:subClassOf rdf:resource="https://guia.org/Degree"/>
        <rdfs:comment xml:lang="en">A postgraduate degree programme corresponding to advanced academic or professional specialization.</rdfs:comment>
        <rdfs:label xml:lang="en">Master&apos;s Degree</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/RemoteActivity -->


    <owl:Class rdf:about="https://guia.org/RemoteActivity">
        <rdfs:comment xml:lang="en">An activity designed to be carried out remotely, typically through online or distance-learning modalities.</rdfs:comment>
        <rdfs:label xml:lang="en">Remote Activity</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/RequiredKnowledge -->


    <owl:Class rdf:about="https://guia.org/RequiredKnowledge">
        <rdfs:comment xml:lang="en">Prior knowledge, skills, or academic background expected from students before taking a course.</rdfs:comment>
        <rdfs:label xml:lang="en">Required Knowledge</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/Schedule -->


    <owl:Class rdf:about="https://guia.org/Schedule">
        <rdfs:subClassOf rdf:resource="https://schema.org/Schedule"/>
        <rdfs:comment xml:lang="en">A temporal organization of course-related events, activities, or milestones across the academic period.</rdfs:comment>
        <rdfs:label xml:lang="en">Schedule</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/ScheduleEvent -->


    <owl:Class rdf:about="https://guia.org/ScheduleEvent">
        <rdfs:subClassOf rdf:resource="https://schema.org/Event"/>
        <rdfs:comment xml:lang="en">A dated or timed element within a course schedule, such as a class session, deadline, exam, or planned activity.</rdfs:comment>
        <rdfs:label xml:lang="en">Schedule Event</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/Syllabus -->


    <owl:Class rdf:about="https://guia.org/Syllabus">
        <rdfs:subClassOf rdf:resource="https://schema.org/Syllabus"/>
        <rdfs:comment xml:lang="en">The structured outline of the course content, usually organized into thematic units, topics, or instructional blocks.</rdfs:comment>
        <rdfs:label xml:lang="en">Syllabus</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/SyllabusItem -->


    <owl:Class rdf:about="https://guia.org/SyllabusItem">
        <rdfs:comment xml:lang="en">A single element of a syllabus, representing a topic, unit, lesson, or other content component within the course structure.</rdfs:comment>
        <rdfs:label xml:lang="en">Syllabus Item</rdfs:label>
    </owl:Class>
    


    <!-- https://guia.org/UniversityCenter -->


    <owl:Class rdf:about="https://guia.org/UniversityCenter">
        <rdfs:subClassOf rdf:resource="https://schema.org/Organization"/>
        <rdfs:description xml:lang="en">An organizational unit within a university where degree programmes are taught, such as a faculty, school, or institute responsible for academic delivery.</rdfs:description>
        <rdfs:label xml:lang="en">University Center</rdfs:label>
    </owl:Class>
    


