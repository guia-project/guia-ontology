<?xml version="1.0"?>
<rdf:RDF xmlns="https://guia.org/"
     xml:base="https://guia.org/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://guia.org/">
        <dc:title xml:lang="en">GUIA ontology</dc:title>
        <terms:creator>Andrea Cimmino Arriaga</terms:creator>
        <terms:creator>Covadonga Arias</terms:creator>
        <terms:license rdf:resource="http://purl.org/NET/rdflicense/cc-by4.0"/>
        <rdfs:comment xml:lang="en">This ontology defines concepts to represent academic course guides in higher education. It models degrees, courses, teaching roles, learning design, resources, schedules, and evaluation systems, while reusing existing vocabularies such as Schema.org whenever possible.</rdfs:comment>
        <rdfs:label xml:lang="en">GUIA Ontology</rdfs:label>
        <owl:versionInfo xml:lang="en">0.1.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#description -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#description"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://guia.org/activityDurationUnit -->


    <owl:ObjectProperty rdf:about="https://guia.org/activityDurationUnit">
        <rdfs:domain rdf:resource="https://guia.org/Activity"/>
        <rdfs:range rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/Unit"/>
        <rdfs:comment xml:lang="en">Links an activity to the unit used to express its duration.</rdfs:comment>
        <rdfs:label xml:lang="en">activity duration unit</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://guia.org/hasActivity -->


    <owl:ObjectProperty rdf:about="https://guia.org/hasActivity">
        <rdfs:domain rdf:resource="https://guia.org/ScheduleEvent"/>
        <rdfs:range rdf:resource="https://guia.org/Activity"/>
        <rdfs:comment xml:lang="en">Links a schedule event to an academic activity carried out during that event.</rdfs:comment>
        <rdfs:label xml:lang="en">has activity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://guia.org/hasCompetency -->


    <owl:ObjectProperty rdf:about="https://guia.org/hasCompetency">
        <rdfs:domain rdf:resource="https://guia.org/CourseGuide"/>
        <rdfs:range rdf:resource="https://guia.org/Competency"/>
        <rdfs:comment xml:lang="en">Links a course guide to a competency developed or addressed in the course.</rdfs:comment>
        <rdfs:label xml:lang="en">has competency</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://guia.org/hasCourse -->


    <owl:ObjectProperty rdf:about="https://guia.org/hasCourse">
        <rdfs:domain rdf:resource="https://guia.org/Degree"/>
        <rdfs:range rdf:resource="https://guia.org/Course"/>
        <rdfs:comment xml:lang="en">Links a degree programme to a course included in its curriculum.</rdfs:comment>
        <rdfs:label xml:lang="en">has course</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://guia.org/hasDidacticResource -->


    <owl:ObjectProperty rdf:about="https://guia.org/hasDidacticResource">
        <rdfs:domain rdf:resource="https://guia.org/CourseGuide"/>
        <rdfs:range rdf:resource="https://guia.org/DidacticResource"/>
        <rdfs:comment xml:lang="en">Links a course guide to a didactic or bibliographic resource used in the course.</rdfs:comment>
        <rdfs:label xml:lang="en">has didactic resource</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://guia.org/hasEvaluation -->


    <owl:ObjectProperty rdf:about="https://guia.org/hasEvaluation">
        <rdfs:domain rdf:resource="https://guia.org/CourseGuide"/>
        <rdfs:range rdf:resource="https://guia.org/EvaluationSystem"/>
        <rdfs:comment xml:lang="en">Links a course guide to its evaluation system.</rdfs:comment>
        <rdfs:label xml:lang="en">has evaluation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://guia.org/hasEvaluationTrial -->


    <owl:ObjectProperty rdf:about="https://guia.org/hasEvaluationTrial">
        <rdfs:domain rdf:resource="https://guia.org/EvaluationSystem"/>
        <rdfs:range rdf:resource="https://guia.org/EvaluationTrial"/>
        <rdfs:comment xml:lang="en">Links an evaluation system to one of its evaluation trials.</rdfs:comment>
        <rdfs:label xml:lang="en">has evaluation trial</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://guia.org/hasItem -->


    <owl:ObjectProperty rdf:about="https://guia.org/hasItem">
        <rdfs:domain rdf:resource="https://guia.org/Syllabus"/>
        <rdfs:range rdf:resource="https://guia.org/SyllabusItem"/>
        <rdfs:comment xml:lang="en">Links a syllabus to one of its constituent syllabus items.</rdfs:comment>
        <rdfs:label xml:lang="en">has item</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://guia.org/hasLearningResult -->


    <owl:ObjectProperty rdf:about="https://guia.org/hasLearningResult">
        <rdfs:domain rdf:resource="https://guia.org/CourseGuide"/>
        <rdfs:range rdf:resource="https://guia.org/LearningResult"/>
        <rdfs:comment xml:lang="en">Links a course guide to a learning result expected from the course.</rdfs:comment>
        <rdfs:label xml:lang="en">has learning result</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://guia.org/hasScheduleEvent -->


    <owl:ObjectProperty rdf:about="https://guia.org/hasScheduleEvent">
        <rdfs:domain rdf:resource="https://guia.org/EvaluationTrial"/>
        <rdfs:range rdf:resource="https://guia.org/ScheduleEvent"/>
        <rdfs:comment xml:lang="en">Links an evaluation trial to the schedule event in which it takes place.</rdfs:comment>
        <rdfs:label xml:lang="en">has schedule event</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://guia.org/involvesCompetency -->


    <owl:ObjectProperty rdf:about="https://guia.org/involvesCompetency">
        <rdfs:domain rdf:resource="https://guia.org/EvaluationTrial"/>
        <rdfs:range rdf:resource="https://guia.org/Competency"/>
        <rdfs:comment xml:lang="en">Links an evaluation trial to a competency involved in that assessment.</rdfs:comment>
        <rdfs:label xml:lang="en">involves competency</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://guia.org/offers -->


    <owl:ObjectProperty rdf:about="https://guia.org/offers">
        <rdfs:domain rdf:resource="https://guia.org/UniversityCenter"/>
        <rdfs:range rdf:resource="https://guia.org/Degree"/>
        <rdfs:comment xml:lang="en">Links a university center to a degree programme that it offers.</rdfs:comment>
        <rdfs:label xml:lang="en">offers</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://guia.org/publishedAt -->


    <owl:ObjectProperty rdf:about="https://guia.org/publishedAt">
        <rdfs:domain rdf:resource="https://guia.org/CourseGuide"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Resource"/>
        <rdfs:comment xml:lang="en">Provides the URL where the course guide is publicly available.</rdfs:comment>
        <rdfs:label xml:lang="en">published at</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.org/courseSchedule -->


    <owl:ObjectProperty rdf:about="https://schema.org/courseSchedule">
        <rdfs:domain rdf:resource="https://guia.org/CourseGuide"/>
        <rdfs:range rdf:resource="https://guia.org/Schedule"/>
        <rdfs:comment xml:lang="en">Links a course guide to the schedule that organizes its planned events.</rdfs:comment>
        <rdfs:label xml:lang="en">course schedule</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.org/director -->


    <owl:ObjectProperty rdf:about="https://schema.org/director">
        <rdfs:domain rdf:resource="https://guia.org/CourseGuide"/>
        <rdfs:range rdf:resource="https://guia.org/Lecturer"/>
        <rdfs:comment xml:lang="en">Links a course guide to the lecturer acting as course coordinator or academic lead.</rdfs:comment>
        <rdfs:label xml:lang="en">director</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.org/eventSchedule -->


    <owl:ObjectProperty rdf:about="https://schema.org/eventSchedule">
        <rdfs:domain rdf:resource="https://guia.org/Schedule"/>
        <rdfs:range rdf:resource="https://guia.org/ScheduleEvent"/>
        <rdfs:comment xml:lang="en">Links a schedule to one of its schedule events.</rdfs:comment>
        <rdfs:label xml:lang="en">event schedule</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.org/hasCourseInstance -->


    <owl:ObjectProperty rdf:about="https://schema.org/hasCourseInstance">
        <rdfs:domain rdf:resource="https://guia.org/Course"/>
        <rdfs:range rdf:resource="https://guia.org/CourseGuide"/>
        <rdfs:comment xml:lang="en">Links a course to a concrete course guide or offering for a given academic period.</rdfs:comment>
        <rdfs:label xml:lang="en">has course instance</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.org/instructor -->


    <owl:ObjectProperty rdf:about="https://schema.org/instructor">
        <rdfs:domain rdf:resource="https://guia.org/CourseGuide"/>
        <rdfs:range rdf:resource="https://guia.org/Lecturer"/>
        <rdfs:comment xml:lang="en">Links a course guide to a lecturer involved in teaching the course.</rdfs:comment>
        <rdfs:label xml:lang="en">instructor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://guia.org/activityDescription -->


    <owl:DatatypeProperty rdf:about="https://guia.org/activityDescription">
        <rdfs:domain rdf:resource="https://guia.org/Activity"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Provides a textual description of an academic activity.</rdfs:comment>
        <rdfs:label xml:lang="en">activity description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/activityDuration -->


    <owl:DatatypeProperty rdf:about="https://guia.org/activityDuration">
        <rdfs:domain rdf:resource="https://guia.org/Activity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">States the duration value assigned to an academic activity.</rdfs:comment>
        <rdfs:label xml:lang="en">activity duration</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/activityFormat -->


    <owl:DatatypeProperty rdf:about="https://guia.org/activityFormat">
        <rdfs:domain rdf:resource="https://guia.org/Activity"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Indicates the delivery format or modality of an academic activity.</rdfs:comment>
        <rdfs:label xml:lang="en">activity format</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/attendanceType -->


    <owl:DatatypeProperty rdf:about="https://guia.org/attendanceType">
        <rdfs:domain rdf:resource="https://guia.org/Activity"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Indicates whether an activity is face-to-face, remote, or follows another attendance modality.</rdfs:comment>
        <rdfs:label xml:lang="en">attendance mode</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/bibliographyDescription -->


    <owl:DatatypeProperty rdf:about="https://guia.org/bibliographyDescription">
        <rdfs:domain rdf:resource="https://guia.org/DidacticResource"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Provides a textual description or reference for a bibliographic or didactic resource.</rdfs:comment>
        <rdfs:label xml:lang="en">bibliography description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/bibliographyTitle -->


    <owl:DatatypeProperty rdf:about="https://guia.org/bibliographyTitle">
        <rdfs:domain rdf:resource="https://guia.org/DidacticResource"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Provides the title or name of a bibliographic or didactic resource.</rdfs:comment>
        <rdfs:label xml:lang="en">bibliography title</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/bibliographyType -->


    <owl:DatatypeProperty rdf:about="https://guia.org/bibliographyType">
        <rdfs:domain rdf:resource="https://guia.org/DidacticResource"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Specifies the category of a bibliographic or didactic resource.</rdfs:comment>
        <rdfs:label xml:lang="en">bibliography type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/courseType -->


    <owl:DatatypeProperty rdf:about="https://guia.org/courseType">
        <rdfs:domain rdf:resource="https://guia.org/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Specifies the academic nature of the course, such as basic, mandatory, elective, or similar categories.</rdfs:comment>
        <rdfs:label xml:lang="en">course type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/degreeCode -->


    <owl:DatatypeProperty rdf:about="https://guia.org/degreeCode">
        <rdfs:domain rdf:resource="https://guia.org/Degree"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Indicates the identification code of a degree.</rdfs:comment>
        <rdfs:label xml:lang="en">degree code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/evaluationDescription -->


    <owl:DatatypeProperty rdf:about="https://guia.org/evaluationDescription">
        <rdfs:domain rdf:resource="https://guia.org/EvaluationSystem"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Describes the criteria, rules, or overall structure of the evaluation system.</rdfs:comment>
        <rdfs:label xml:lang="en">evaluation description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/evaluationDuration -->


    <owl:DatatypeProperty rdf:about="https://guia.org/evaluationDuration">
        <rdfs:domain rdf:resource="https://guia.org/EvaluationTrial"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">States the duration of an evaluation activity or trial.</rdfs:comment>
        <rdfs:label xml:lang="en">evaluation duration</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/evaluationType -->


    <owl:DatatypeProperty rdf:about="https://guia.org/evaluationType">
        <rdfs:domain rdf:resource="https://guia.org/EvaluationTrial"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Specifies a local type classification used for an activity or evaluation element. For instance, in spanish university the following categories exist: progressive, final, extraordinay.</rdfs:comment>
        <rdfs:comment xml:lang="en">Specifies the type of evaluation associated with an assessment activity or trial.</rdfs:comment>
        <rdfs:label xml:lang="en">evaluation type</rdfs:label>
        <rdfs:label xml:lang="en">type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/gradePercentage -->


    <owl:DatatypeProperty rdf:about="https://guia.org/gradePercentage">
        <rdfs:domain rdf:resource="https://guia.org/EvaluationTrial"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Specifies the percentage weight of an evaluation activity in the final grade.</rdfs:comment>
        <rdfs:label xml:lang="en">grade percentage</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/inpersonHours -->


    <owl:DatatypeProperty rdf:about="https://guia.org/inpersonHours">
        <rdfs:domain rdf:resource="https://guia.org/CourseGuide"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Specifies the number or description of face-to-face hours within the course guide.</rdfs:comment>
        <rdfs:label xml:lang="en">in-person hours</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/minimumScore -->


    <owl:DatatypeProperty rdf:about="https://guia.org/minimumScore">
        <rdfs:domain rdf:resource="https://guia.org/EvaluationTrial"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Indicates the minimum score required for an evaluation activity or assessment component.</rdfs:comment>
        <rdfs:label xml:lang="en">minimum score</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/numberOfCredits -->


    <owl:DatatypeProperty rdf:about="https://guia.org/numberOfCredits">
        <rdfs:domain rdf:resource="https://guia.org/CourseGuide"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">States the number of academic credits assigned to a course guide or course offering.</rdfs:comment>
        <rdfs:label xml:lang="en">number of credits</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/office -->


    <owl:DatatypeProperty rdf:about="https://guia.org/office">
        <rdfs:domain rdf:resource="https://guia.org/Lecturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Provides the office or location assigned to a lecturer for student attention.</rdfs:comment>
        <rdfs:label xml:lang="en">office</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/otherInformation -->


    <owl:DatatypeProperty rdf:about="https://guia.org/otherInformation">
        <rdfs:domain rdf:resource="https://guia.org/CourseGuide"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Provides additional general information relevant to the course guide.</rdfs:comment>
        <rdfs:label xml:lang="en">other information</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/periodEndingMonth -->


    <owl:DatatypeProperty rdf:about="https://guia.org/periodEndingMonth">
        <rdfs:domain rdf:resource="https://guia.org/CourseGuide"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Indicates the month in which the teaching period ends.</rdfs:comment>
        <rdfs:label xml:lang="en">period ending month</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/periodStaringtMonth -->


    <owl:DatatypeProperty rdf:about="https://guia.org/periodStaringtMonth">
        <rdfs:domain rdf:resource="https://guia.org/CourseGuide"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Indicates the month in which the teaching period starts.</rdfs:comment>
        <rdfs:label xml:lang="en">period starting month</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/previousCourses -->


    <owl:DatatypeProperty rdf:about="https://guia.org/previousCourses">
        <rdfs:domain rdf:resource="https://guia.org/RequiredKnowledge"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Provides a textual statement about prior courses recommended or required before taking the course.</rdfs:comment>
        <rdfs:label xml:lang="en">previous courses</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/previousKnowledge -->


    <owl:DatatypeProperty rdf:about="https://guia.org/previousKnowledge">
        <rdfs:domain rdf:resource="https://guia.org/RequiredKnowledge"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Describes prior knowledge or skills expected from students before taking the course.</rdfs:comment>
        <rdfs:label xml:lang="en">previous knowledge</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/remoteHours -->


    <owl:DatatypeProperty rdf:about="https://guia.org/remoteHours">
        <rdfs:domain rdf:resource="https://guia.org/CourseGuide"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Specifies the number or description of remote hours within the course guide.</rdfs:comment>
        <rdfs:label xml:lang="en">remote hours</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/semester -->


    <owl:DatatypeProperty rdf:about="https://guia.org/semester">
        <rdfs:domain rdf:resource="https://guia.org/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Indicates the semester or semesters in which a course is taught.</rdfs:comment>
        <rdfs:label xml:lang="en">semester</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/teachingPeriod -->


    <owl:DatatypeProperty rdf:about="https://guia.org/teachingPeriod">
        <rdfs:domain rdf:resource="https://guia.org/CourseGuide"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Identifies the academic year to which the course guide applies.</rdfs:comment>
        <rdfs:label xml:lang="en">teaching period</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/teachingPeriodMonths -->


    <owl:DatatypeProperty rdf:about="https://guia.org/teachingPeriodMonths">
        <rdfs:domain rdf:resource="https://guia.org/CourseGuide"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Describes the months or span of months during which the course is taught.</rdfs:comment>
        <rdfs:label xml:lang="en">teaching period months</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/totalHours -->


    <owl:DatatypeProperty rdf:about="https://guia.org/totalHours">
        <rdfs:domain rdf:resource="https://guia.org/CourseGuide"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">States the total student workload of the course guide expressed in hours.</rdfs:comment>
        <rdfs:label xml:lang="en">total hours</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://guia.org/trialDescription -->


    <owl:DatatypeProperty rdf:about="https://guia.org/trialDescription">
        <rdfs:domain rdf:resource="https://guia.org/EvaluationTrial"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
